// Cariri Burguer — Gerenciador de pedidos (online + presencial)
// Todos os valores monetários são armazenados em CENTAVOS (Int).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// LOJA / CONFIGURAÇÃO
// ─────────────────────────────────────────────────────────────

model Store {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  document     String? // CNPJ ou CPF
  whatsapp     String?
  minOrder     Int      @default(0) // centavos
  prepTime     Int      @default(40) // minutos
  active       Boolean  @default(true)

  // Identidade visual
  primaryColor String   @default("#F2611F")
  logoUrl      String?
  coverUrl     String?

  // Endereço da loja
  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  lat          Float?
  lng          Float?

  // Entrega
  deliveryMode      DeliveryMode @default(KM)
  freeShippingAbove Int? // centavos; null = desativado

  // Pagamento
  pixKey     String?
  pixKeyType String? // CPF | CNPJ | EMAIL | PHONE | RANDOM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hours          BusinessHour[]
  categories     Category[]
  products       Product[]
  complementGroups ComplementGroup[]
  customers      Customer[]
  coupons        Coupon[]
  deliveryZones  DeliveryZone[]
  paymentConfigs PaymentConfig[]
  tables         RestaurantTable[]
  orders         Order[]
  drivers        Driver[]
  users          User[]
  cashRegisters  CashRegister[]
}

model BusinessHour {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  weekday   Int // 0 = domingo ... 6 = sábado
  openTime  String // "18:00"
  closeTime String // "23:30"
  active    Boolean @default(true)

  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// CARDÁPIO
// ─────────────────────────────────────────────────────────────

model Category {
  id       String  @id @default(cuid())
  storeId  String
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name     String
  emoji    String?
  position Int     @default(0)
  active   Boolean @default(true)

  products Product[]

  @@index([storeId])
}

enum ProductType {
  COMMON
  COMBO
  PIZZA
  WEIGHT
}

model Product {
  id          String      @id @default(cuid())
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type        ProductType @default(COMMON)

  name        String
  description String?
  price       Int // centavos
  promoPrice  Int? // centavos; preço com desconto
  images      String[]    @default([])

  measureValue String? // ex: "730"
  measureUnit  String? // ex: "g", "ml", "un"
  serves       Int? // serve quantas pessoas
  stock        Int?
  pdvCode      String?

  active           Boolean @default(true)
  featured         Boolean @default(false)
  availableDelivery Boolean @default(true) // entrega e retirada
  availableDineIn   Boolean @default(true) // mesa e balcão
  position         Int     @default(0)

  tags                String[] @default([]) // etiquetas
  removableIngredients String[] @default([]) // remoção de ingredientes

  complementLinks ProductComplementGroup[]
  orderItems      OrderItem[]

  @@index([storeId])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────
// ADICIONAIS / COMPLEMENTOS (grupos reutilizáveis)
// ─────────────────────────────────────────────────────────────

model ComplementGroup {
  id          String  @id @default(cuid())
  storeId     String
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  active      Boolean @default(true)
  position    Int     @default(0)

  items        ComplementItem[]
  productLinks ProductComplementGroup[]

  @@index([storeId])
}

model ComplementItem {
  id          String   @id @default(cuid())
  groupId     String
  group       ComplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Int      @default(0) // centavos
  imageUrl    String?
  pdvCode     String?
  stock       Int?
  active      Boolean  @default(true)
  position    Int      @default(0)

  orderItemComplements OrderItemComplement[]

  @@index([groupId])
}

// Vínculo grupo<->produto com as regras (obrigatoriedade, min, max)
model ProductComplementGroup {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String
  group     ComplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  required  Boolean @default(false)
  min       Int     @default(0)
  max       Int     @default(0) // 0 = sem limite
  position  Int     @default(0)

  @@unique([productId, groupId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  notes     String? // anotações internas
  createdAt DateTime @default(now())

  addresses Address[]
  orders    Order[]

  @@unique([storeId, phone])
  @@index([storeId])
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  street       String
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  complement   String?
  reference    String?
  lat          Float?
  lng          Float?

  orders Order[]

  @@index([customerId])
}

// ─────────────────────────────────────────────────────────────
// CUPONS / ENTREGA / PAGAMENTO
// ─────────────────────────────────────────────────────────────

enum DiscountType {
  FIXED
  PERCENT
}

model Coupon {
  id              String       @id @default(cuid())
  storeId         String
  store           Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code            String
  discountType    DiscountType @default(PERCENT)
  discountValue   Int // PERCENT: 0-100 | FIXED: centavos
  minOrder        Int? // centavos
  freeShipping    Boolean      @default(false)
  perCustomerLimit Int?
  totalLimit      Int?
  usedCount       Int          @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  active          Boolean      @default(true)

  orders Order[]

  @@unique([storeId, code])
  @@index([storeId])
}

enum DeliveryMode {
  KM
  NEIGHBORHOOD
  FIXED
}

model DeliveryZone {
  id         String  @id @default(cuid())
  storeId    String
  store      Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  label      String? // nome do bairro (modo NEIGHBORHOOD)
  maxKm      Float? // raio até X km (modo KM)
  fee        Int     @default(0) // centavos
  etaMinutes Int     @default(30)
  active     Boolean @default(true)
  position   Int     @default(0)

  @@index([storeId])
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT
  DEBIT
  MEAL_VOUCHER
  FOOD_VOUCHER
}

model PaymentConfig {
  id             String        @id @default(cuid())
  storeId        String
  store          Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  method         PaymentMethod
  enabledDelivery Boolean      @default(true)
  enabledPickup  Boolean       @default(true)
  extraFeePercent Float        @default(0)

  @@unique([storeId, method])
  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// MESAS / ENTREGADORES
// ─────────────────────────────────────────────────────────────

enum TableStatus {
  FREE
  OCCUPIED
}

model RestaurantTable {
  id      String      @id @default(cuid())
  storeId String
  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  number  Int
  status  TableStatus @default(FREE)

  orders Order[]

  @@unique([storeId, number])
  @@index([storeId])
}

model Driver {
  id      String  @id @default(cuid())
  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String
  phone   String?
  active  Boolean @default(true)

  orders Order[]

  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────────

enum OrderType {
  DELIVERY
  PICKUP
  DINEIN
}

enum OrderStatus {
  NEW
  PREPARING
  DELIVERING
  COMPLETED
  CANCELED
}

enum OrderChannel {
  ONLINE
  PDV
}

model Order {
  id      String       @id @default(cuid())
  storeId String
  store   Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code    String // ex: "001-291962"
  type    OrderType    @default(DELIVERY)
  status  OrderStatus  @default(NEW)
  channel OrderChannel @default(ONLINE)

  // Cliente (snapshot + relação opcional)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerName String?
  customerPhone String?

  // Endereço (entrega)
  addressId       String?
  address         Address? @relation(fields: [addressId], references: [id])
  addressSnapshot String?

  // Mesa / balcão
  tableId   String?
  table     RestaurantTable? @relation(fields: [tableId], references: [id])
  comanda   String?
  attendant String?

  // Pagamento
  paymentMethod PaymentMethod?
  changeFor     Int? // troco para (centavos)

  // Valores (centavos)
  subtotal    Int @default(0)
  deliveryFee Int @default(0)
  paymentFee  Int @default(0)
  discount    Int @default(0)
  surcharge   Int @default(0)
  tip         Int @default(0)
  total       Int @default(0)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  note        String?
  scheduledFor DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  name      String // snapshot
  unitPrice Int // centavos (produto base)
  quantity  Int    @default(1)
  totalPrice Int // centavos (com adicionais * qtd)
  note      String? // observação

  complements OrderItemComplement[]

  @@index([orderId])
}

model OrderItemComplement {
  id          String  @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  complementItemId String?
  complementItem   ComplementItem? @relation(fields: [complementItemId], references: [id])
  name        String // snapshot
  price       Int    @default(0) // centavos
  quantity    Int    @default(1)

  @@index([orderItemId])
}

// ─────────────────────────────────────────────────────────────
// CAIXA
// ─────────────────────────────────────────────────────────────

enum CashStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id             String     @id @default(cuid())
  storeId        String
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status         CashStatus @default(OPEN)
  openingBalance Int        @default(0) // centavos
  countedBalance Int? // valor informado no fechamento
  note           String?
  openedAt       DateTime   @default(now())
  closedAt       DateTime?
  openedBy       String?

  movements CashMovement[]

  @@index([storeId])
}

enum CashMovementType {
  IN
  OUT
  SALE
}

model CashMovement {
  id          String   @id @default(cuid())
  registerId  String
  register    CashRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
  type        CashMovementType
  amount      Int // centavos
  description String?
  createdAt   DateTime @default(now())

  @@index([registerId])
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS / ACESSOS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

model User {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([storeId])
}
