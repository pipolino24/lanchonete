// Cariri Burguer — Gerenciador de pedidos (online + presencial)
// Banco: MongoDB Atlas. Todos os valores monetários são em CENTAVOS (Int).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// LOJA / CONFIGURAÇÃO
// ─────────────────────────────────────────────────────────────

model Store {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String  @unique
  document     String?
  whatsapp     String?
  minOrder     Int     @default(0)
  prepTime     Int     @default(40)
  active       Boolean @default(true)

  primaryColor String  @default("#F2611F")
  logoUrl      String?
  coverUrl     String?

  street       String?
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  lat          Float?
  lng          Float?

  deliveryMode      DeliveryMode @default(KM)
  freeShippingAbove Int?

  pixKey     String?
  pixKeyType String?

  cartMessage String? // recado exibido no carrinho do cliente

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hours            BusinessHour[]
  categories       Category[]
  products         Product[]
  complementGroups ComplementGroup[]
  customers        Customer[]
  coupons          Coupon[]
  deliveryZones    DeliveryZone[]
  paymentConfigs   PaymentConfig[]
  tables           RestaurantTable[]
  orders           Order[]
  drivers          Driver[]
  users            User[]
  cashRegisters    CashRegister[]
}

model BusinessHour {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  storeId   String  @db.ObjectId
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  weekday   Int
  openTime  String
  closeTime String
  active    Boolean @default(true)

  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// CARDÁPIO
// ─────────────────────────────────────────────────────────────

model Category {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  storeId  String  @db.ObjectId
  store    Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name     String
  emoji    String?
  position Int     @default(0)
  active   Boolean @default(true)

  products Product[]

  @@index([storeId])
}

enum ProductType {
  COMMON
  COMBO
  PIZZA
  WEIGHT
}

model Product {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String      @db.ObjectId
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String      @db.ObjectId
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type        ProductType @default(COMMON)

  name        String
  description String?
  price       Int
  promoPrice  Int?
  images      String[]    @default([])

  measureValue String?
  measureUnit  String?
  serves       Int?
  stock        Int?
  pdvCode      String?

  active            Boolean @default(true)
  featured          Boolean @default(false)
  availableDelivery Boolean @default(true)
  availableDineIn   Boolean @default(true)
  position          Int     @default(0)

  tags                 String[] @default([])
  removableIngredients String[] @default([])

  complementLinks ProductComplementGroup[]
  orderItems      OrderItem[]

  @@index([storeId])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────
// ADICIONAIS / COMPLEMENTOS
// ─────────────────────────────────────────────────────────────

model ComplementGroup {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  storeId     String  @db.ObjectId
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  active      Boolean @default(true)
  position    Int     @default(0)

  items        ComplementItem[]
  productLinks ProductComplementGroup[]

  @@index([storeId])
}

model ComplementItem {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String          @db.ObjectId
  group       ComplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Int     @default(0)
  imageUrl    String?
  pdvCode     String?
  stock       Int?
  active      Boolean @default(true)
  position    Int     @default(0)

  orderItemComplements OrderItemComplement[]

  @@index([groupId])
}

model ProductComplementGroup {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  productId String          @db.ObjectId
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  groupId   String          @db.ObjectId
  group     ComplementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  required  Boolean @default(false)
  min       Int     @default(0)
  max       Int     @default(0)
  position  Int     @default(0)

  @@unique([productId, groupId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId   String   @db.ObjectId
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  notes     String?
  createdAt DateTime @default(now())

  addresses Address[]
  orders    Order[]

  @@unique([storeId, phone])
  @@index([storeId])
}

model Address {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  customerId   String   @db.ObjectId
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  street       String
  number       String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  complement   String?
  reference    String?
  lat          Float?
  lng          Float?

  orders Order[]

  @@index([customerId])
}

// ─────────────────────────────────────────────────────────────
// CUPONS / ENTREGA / PAGAMENTO
// ─────────────────────────────────────────────────────────────

enum DiscountType {
  FIXED
  PERCENT
}

model Coupon {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  storeId          String       @db.ObjectId
  store            Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code             String
  discountType     DiscountType @default(PERCENT)
  discountValue    Int
  minOrder         Int?
  freeShipping     Boolean      @default(false)
  perCustomerLimit Int?
  totalLimit       Int?
  usedCount        Int          @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  active           Boolean      @default(true)

  orders Order[]

  @@unique([storeId, code])
  @@index([storeId])
}

enum DeliveryMode {
  KM
  NEIGHBORHOOD
  FIXED
}

model DeliveryZone {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  storeId    String  @db.ObjectId
  store      Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  label      String?
  maxKm      Float?
  fee        Int     @default(0)
  etaMinutes Int     @default(30)
  active     Boolean @default(true)
  position   Int     @default(0)

  @@index([storeId])
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT
  DEBIT
  MEAL_VOUCHER
  FOOD_VOUCHER
}

model PaymentConfig {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  storeId         String        @db.ObjectId
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  enabledDelivery Boolean       @default(true)
  enabledPickup   Boolean       @default(true)
  extraFeePercent Float         @default(0)

  @@unique([storeId, method])
  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// MESAS / ENTREGADORES
// ─────────────────────────────────────────────────────────────

enum TableStatus {
  FREE
  OCCUPIED
}

model RestaurantTable {
  id      String      @id @default(auto()) @map("_id") @db.ObjectId
  storeId String      @db.ObjectId
  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  number  Int
  status  TableStatus @default(FREE)

  orders Order[]

  @@unique([storeId, number])
  @@index([storeId])
}

model Driver {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  storeId String  @db.ObjectId
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String
  phone   String?
  active  Boolean @default(true)

  orders Order[]

  @@index([storeId])
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────────

enum OrderType {
  DELIVERY
  PICKUP
  DINEIN
}

enum OrderStatus {
  NEW
  PREPARING
  DELIVERING
  COMPLETED
  CANCELED
}

enum OrderChannel {
  ONLINE
  PDV
}

model Order {
  id      String       @id @default(auto()) @map("_id") @db.ObjectId
  storeId String       @db.ObjectId
  store   Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  code    String
  type    OrderType    @default(DELIVERY)
  status  OrderStatus  @default(NEW)
  channel OrderChannel @default(ONLINE)

  customerId    String?   @db.ObjectId
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String?
  customerPhone String?

  addressId       String?  @db.ObjectId
  address         Address? @relation(fields: [addressId], references: [id])
  addressSnapshot String?

  tableId   String?          @db.ObjectId
  table     RestaurantTable? @relation(fields: [tableId], references: [id])
  comanda   String?
  attendant String?

  paymentMethod PaymentMethod?
  changeFor     Int?

  subtotal    Int @default(0)
  deliveryFee Int @default(0)
  paymentFee  Int @default(0)
  discount    Int @default(0)
  surcharge   Int @default(0)
  tip         Int @default(0)
  total       Int @default(0)

  couponId String? @db.ObjectId
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  driverId String? @db.ObjectId
  driver   Driver? @relation(fields: [driverId], references: [id])

  note         String?
  scheduledFor DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model OrderItem {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String   @db.ObjectId
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String?  @db.ObjectId
  product    Product? @relation(fields: [productId], references: [id])

  name       String
  unitPrice  Int
  quantity   Int     @default(1)
  totalPrice Int
  note       String?

  complements OrderItemComplement[]

  @@index([orderId])
}

model OrderItemComplement {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  orderItemId      String          @db.ObjectId
  orderItem        OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  complementItemId String?         @db.ObjectId
  complementItem   ComplementItem? @relation(fields: [complementItemId], references: [id])
  name             String
  price            Int     @default(0)
  quantity         Int     @default(1)

  @@index([orderItemId])
}

// ─────────────────────────────────────────────────────────────
// CAIXA
// ─────────────────────────────────────────────────────────────

enum CashStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id             String     @id @default(auto()) @map("_id") @db.ObjectId
  storeId        String     @db.ObjectId
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  status         CashStatus @default(OPEN)
  openingBalance Int        @default(0)
  countedBalance Int?
  note           String?
  openedAt       DateTime   @default(now())
  closedAt       DateTime?
  openedBy       String?

  movements CashMovement[]

  @@index([storeId])
}

enum CashMovementType {
  IN
  OUT
  SALE
}

model CashMovement {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  registerId  String           @db.ObjectId
  register    CashRegister     @relation(fields: [registerId], references: [id], onDelete: Cascade)
  type        CashMovementType
  amount      Int
  description String?
  createdAt   DateTime @default(now())

  @@index([registerId])
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  storeId      String   @db.ObjectId
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([storeId])
}
